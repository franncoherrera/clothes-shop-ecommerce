    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "swiper": "^12.0.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "prisma": "^6.16.2",
